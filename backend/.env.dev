# Development Environment - Local Testing
DJANGO_SECRET_KEY=django-insecure-dev-key-do-not-use-in-production-abc123xyz
DJANGO_DEBUG=True
DJANGO_ENV=development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/connector_db
DB_NAME=connector_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1

# JWT
JWT_SECRET_KEY=dev-jwt-secret-key-12345
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=604800

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000

# File Storage
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles
EXPORT_PATH=/app/media/exports
MAX_UPLOAD_SIZE=104857600

# Connection Settings
DB_CONNECTION_TIMEOUT=30
DB_QUERY_TIMEOUT=60
BATCH_SIZE_DEFAULT=100
BATCH_SIZE_MAX=1000

# Rate Limiting (relaxed for development)
RATE_LIMIT_ANON=1000/day
RATE_LIMIT_USER=10000/day
RATE_LIMIT_EXTRACTION=500/hour

# Email (console backend for development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Logging
LOG_LEVEL=DEBUG
LOG_FILE_PATH=/app/logs/django.log

# Feature Flags
ENABLE_ASYNC_EXTRACTION=False
ENABLE_FILE_COMPRESSION=False
ENABLE_AUDIT_LOGGING=True