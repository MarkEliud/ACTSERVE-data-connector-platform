# =============================================================================
# Data Connector Platform - Environment Configuration Template
# Copy this file to .env.dev or .env.prod and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core Settings
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-in-production-use-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ENV=development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Database Configuration (Main Application Database - PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/connector_db
DB_NAME=connector_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------------------------------------------
# Redis Configuration (Cache & Celery Broker)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# -----------------------------------------------------------------------------
# JWT Authentication Settings
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=604800

# -----------------------------------------------------------------------------
# CORS Settings
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# File Storage Settings
# -----------------------------------------------------------------------------
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles
EXPORT_PATH=/app/media/exports
MAX_UPLOAD_SIZE=104857600

# -----------------------------------------------------------------------------
# Connection Settings for External Databases
# -----------------------------------------------------------------------------
DB_CONNECTION_TIMEOUT=30
DB_QUERY_TIMEOUT=60
BATCH_SIZE_DEFAULT=1000
BATCH_SIZE_MAX=10000

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ANON=100/day
RATE_LIMIT_USER=1000/day
RATE_LIMIT_EXTRACTION=100/hour

# -----------------------------------------------------------------------------
# Email Configuration (Optional - for notifications)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE_PATH=/app/logs/django.log

# -----------------------------------------------------------------------------
# Sentry/Error Tracking (Optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------
ENABLE_ASYNC_EXTRACTION=True
ENABLE_FILE_COMPRESSION=False
ENABLE_AUDIT_LOGGING=True